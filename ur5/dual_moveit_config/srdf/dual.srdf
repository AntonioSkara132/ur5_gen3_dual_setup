<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="${name}">

  <xacro:arg name="name" default="dual"/>

  <xacro:include filename="$(find ur_dual_bringup)/srdf/ur_macro.srdf.xacro"/>
  <xacro:include filename="$(find dual_moveit_config)/srdf/gen3.srdf.xacro"/>

  <xacro:ur_srdf prefix="ur_"/>
  <xacro:kinova_srdf/>

</robot>
